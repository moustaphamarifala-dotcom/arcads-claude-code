# ── TOUTES CES CLÉS SONT OPTIONNELLES ──────────────────────────────
# Sans aucune clé, l'application fonctionne en MODE GRATUIT :
#   - Textes  : Pollinations.ai (gratuit, sans inscription)
#   - Images  : Pollinations.ai (gratuit, sans inscription)
#   - Vidéos  : indisponibles (aucune API vidéo gratuite fiable n'existe)

# Optionnel — meilleure qualité de textes avec Claude — https://platform.claude.com
# ANTHROPIC_API_KEY=sk-ant-...

# Optionnel — meilleure qualité d'images (FLUX) + active les vidéos (WAN)
# https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_...

# Studio Couture (page /couture) — Nano Banana de Google.
# Clé gratuite (quota gratuit) sur https://aistudio.google.com/apikey
# GOOGLE_API_KEY=AIza...
# (Optionnel) choisir le modèle image : gemini-2.5-flash-image (défaut) ou gemini-3-pro-image-preview
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
