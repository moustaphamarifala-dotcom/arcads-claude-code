# Identifiants API Higgsfield — https://platform.higgsfield.ai
# Format : KEY_ID:KEY_SECRET
HF_CREDENTIALS=VOTRE_KEY_ID:VOTRE_KEY_SECRET

# Alternative (au lieu de HF_CREDENTIALS) :
# HF_API_KEY=VOTRE_KEY_ID
# HF_API_SECRET=VOTRE_KEY_SECRET

# Optionnel : webhook pour recevoir les résultats sans polling
# HF_WEBHOOK_URL=https://votre-domaine.com/webhooks/higgsfield
# HF_WEBHOOK_SECRET=un-secret-partage
